<?xml version="1.0" encoding="UTF-8"?>
<kcfg xmlns="http://www.kde.org/standards/kcfg/1.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.kde.org/standards/kcfg/1.0
      http://www.kde.org/standards/kcfg/1.0/kcfg.xsd">
    <kcfgfile name=""/>

    <group name="General">
        <entry name="provider" type="String">
            <label>Usage provider</label>
            <default>claude</default>
        </entry>
        <entry name="opencodeSubProvider" type="String">
            <label>OpenCode sub-provider</label>
            <default>anthropic</default>
        </entry>
        <entry name="opencodeAccountIndex" type="Int">
            <label>OpenCode Anthropic account index</label>
            <default>0</default>
        </entry>
        <entry name="language" type="String">
            <label>UI Language</label>
            <default>system</default>
        </entry>
        <entry name="refreshInterval" type="Int">
            <label>Refresh interval in minutes</label>
            <default>5</default>
        </entry>
        <entry name="displayName" type="String">
            <label>Display name for the widget</label>
            <default></default>
        </entry>
        <entry name="credentialsPath" type="String">
            <label>Path to credentials file</label>
            <default></default>
        </entry>
        <entry name="sessionWeeklyRatio" type="Int">
            <label>Session-to-weekly ratio (1 full 5hr session = N% weekly)</label>
            <default>10</default>
        </entry>
        <entry name="paceFormat" type="String">
            <label>Pace display format</label>
            <default>percent</default>
        </entry>
        <entry name="sessionColorMode" type="String">
            <label>Session bar color mode</label>
            <default>capacity</default>
        </entry>
        <entry name="weeklyColorMode" type="String">
            <label>Weekly bar color mode</label>
            <default>efficiency</default>
        </entry>
        <entry name="claudeRefreshMinutes" type="Int">
            <label>Claude refresh interval in minutes (min 10)</label>
            <default>15</default>
        </entry>
        <entry name="showBankedBadge" type="Bool">
            <label>Show Codex banked reset badge</label>
            <default>true</default>
        </entry>
        <entry name="discoverOnLoad" type="Bool">
            <label>Discover profiles on widget load</label>
            <default>true</default>
        </entry>
        <entry name="multiProfileMode" type="Bool">
            <label>Multi-profile dashboard (false = legacy single profile)</label>
            <default>true</default>
        </entry>
        <entry name="profileDisplayNamesJson" type="String">
            <label>Custom profile display names JSON map</label>
            <default>{}</default>
        </entry>
        <entry name="enabledProfilesJson" type="String">
            <label>Enabled profile ids JSON array (empty = all)</label>
            <default>[]</default>
        </entry>
        <entry name="visibleWindowsJson" type="String">
            <label>Per-provider window visibility JSON (object map or legacy array; empty = defaults)</label>
            <default>[]</default>
        </entry>
        <entry name="customProfilesJson" type="String">
            <label>Custom profile paths JSON array</label>
            <default>[]</default>
        </entry>
        <entry name="customProfileNextId" type="Int">
            <label>Next monotonic custom profile id</label>
            <default>0</default>
        </entry>
        <entry name="cacheResponses" type="Bool">
            <label>Cache provider API responses to disk</label>
            <default>true</default>
        </entry>
        <entry name="responseCachePath" type="String">
            <label>Override root for response cache (empty = ~/.cache/plasma-claude-usage)</label>
            <default></default>
        </entry>
        <entry name="notifyOnQuotaReset" type="Bool">
            <label>Show a celebration notification when a quota window resets</label>
            <default>true</default>
        </entry>
        <entry name="logQuotaResets" type="Bool">
            <label>Log quota reset events under the cache root (resets/)</label>
            <default>true</default>
        </entry>
    </group>
</kcfg>
